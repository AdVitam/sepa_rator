				<xd:restriction base="_:CreditTransferTransactionInformation10">
					<xd:sequence>
						<xd:element name="PmtId" type="_:PaymentIdentification1" xml:ToC="2;Auftraggeberreferenz">
							<xd:annotation>
								<!--  ***** xml:ToC used by style sheet that generats documentation ***** -->
